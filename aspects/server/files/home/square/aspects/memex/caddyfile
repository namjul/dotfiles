samho.xyz, memex.samho.xyz, samuel.hobl.at, tools.samho.xyz {
  handle_path /site-assets* {
    root * {$SQUARE_PATH}/aspects/memex/assets
    try_files {path} {path}
    file_server
  }

  handle_path /decks* {
    root * {$SQUARE_PATH}/data/share/memex/decks
    file_server browse
  }

  @samuelHoblHost {
    host samuel.hobl.at
  }

  @samho {
    host samho.xyz
  }

  handle @samuelHoblHost {
    handle_path / {
      rewrite * /personal-website
    }
  }

  handle @samho {
    redir https://memex.samho.xyz
  }

  @tools {
    host tools.samho.xyz
  }

  handle @tools {
    rewrite / /tool.llm.index.html
    @toolpath path_regexp tool ^/(.+)$
    rewrite @toolpath /tool.llm.{re.tool.1}
  }

  reverse_proxy localhost:8088
}

www.hobl.at, hobl.at {
    redir https://samuel.hobl.at
}

