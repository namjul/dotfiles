# official repo packages

# system
sudo pacman -S --needed --noconfirm cmake pkgconf clang unzip # build tools
sudo pacman -S --needed --noconfirm procps-ng curl file # paru essentials
sudo pacman -S --needed --noconfirm i3-wm # window manager
sudo pacman -S --needed --noconfirm feh # background image
sudo pacman -S --needed --noconfirm zathura zathura-pdf-mupdf # document viewer
sudo pacman -S --needed --noconfirm cryptsetup # used for tomb
sudo pacman -S --needed --noconfirm pass # https://www.passwordstore.org/
sudo pacman -S --needed --noconfirm flameshot # https://github.com/flameshot-org/flameshot
sudo pacman -S --needed --noconfirm nsxiv # https://github.com/nsxiv/nsxiv
sudo pacman -S --needed --noconfirm vlc # https://github.com/videolan/vlc
sudo pacman -S --needed --noconfirm dunst # https://github.com/dunst-project/dunst
sudo pacman -S --needed --noconfirm pipewire pipewire-alsa pipewire-pulse pipewire-jack wireplumber # audio stack
sudo pacman -S --needed --noconfirm interception-tools # https://gitlab.com/interception/linux/tools
