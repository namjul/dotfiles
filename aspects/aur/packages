sudo pacman -S --needed --noconfirm lf # https://github.com/gokcehan/lf
sudo pacman -S --needed --noconfirm tree xclip xsel wmctrl
sudo pacman -S --needed --noconfirm ripgrep # https://github.com/BurntSushi/ripgrep
# paru -S --needed --noconfirm github-cli # https://cli.github.com
sudo pacman -S --needed --noconfirm translate-shell # https://github.com/soimort/translate-shell
sudo pacman -S --needed --noconfirm mise # https://mise.jdx.dev
