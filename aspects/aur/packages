#!/bin/bash
# mise description="Set up AUR environment (paru) and install packages"

trap 'echo "Warning: A command has failed. Exiting the script. Line was ($0:$LINENO): $(sed -n "${LINENO}p" "$0")"; exit 3' ERR
set -Eeuo pipefail

if [[ -e /run/fig-test-container ]]; then
  sudo() { "$@"; }
fi

# base-devel is required to build any AUR package
sudo pacman -S --needed --noconfirm base-devel git

# reflector: keep mirrorlist fresh and fast
sudo pacman -S --needed --noconfirm reflector
sudo reflector --country Germany --age 12 --protocol https --sort rate --download-timeout 5 --save /etc/pacman.d/mirrorlist
sudo systemctl enable --now reflector.timer

# pacman-contrib: paccache prunes the package cache to prevent unbounded growth
sudo pacman -S --needed --noconfirm pacman-contrib
sudo systemctl enable --now paccache.timer

# install paru AUR helper (https://github.com/Morganamilo/paru)
