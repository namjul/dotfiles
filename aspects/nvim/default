#!/usr/bin/env -S deno run --allow-all

import { fs } from "zx";
import { command, fetch, file, init, path, variable, variables } from "fig";

init(import.meta.dirname);

variables(() => ({
  files: [".vimrc", ".config/nvim"],
}));

const NEOVIM_VERSION = "v0.11.4";

// make directories
{
  await file({ path: "~/opt/nvim", state: "directory" });
  await file({ path: "~/.config", state: "directory" });
}

// download neovim appimage only if not already provided by system package manager
const location = `${path.home}/opt/nvim/nvim${NEOVIM_VERSION}.appimage`;
const systemNeovim = Deno.env.get("PATH")?.split(":").some((p) => {
  try { Deno.statSync(`${p}/nvim`); return true; } catch { return false; }
});
if (!systemNeovim && !fs.existsSync(location)) {
  await fetch({
    url:
      `https://github.com/neovim/neovim/releases/download/${NEOVIM_VERSION}/nvim-linux-x86_64.appimage`,
    dest: location,
    mode: "0755",
  });
  await command(location, ['--appimage-extract'], {
    chdir: path.home.join('/opt/nvim').toString(),
  });
}


// create symlinks
{
  const files = await variable.paths("files");

  for (const src of files) {
    await file({
      force: true,
      path: path.home.join(src).toString(),
      src: path.aspect.join("files", src).toString(),
      state: "link",
    });
  }
}
