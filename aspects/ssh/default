#!/usr/bin/env -S deno run --allow-all

import { $, fs, os, path, spinner } from "zx";

/**
# mise description="Manages local SSH config"
# mise alias="ssh"
*/

const aspect = import.meta.dirname ?? 'ssh'

await spinner('create ~/.ssh', async () => {
  await fs.ensureDir("~/.ssh")
})

await spinner('install ~/.ssh/config', async () => {
  const unit = '.ssh/config';
  const encryptedSource = path.join(aspect, 'files', unit + '.encrypted')
  const plainSource = path.join(aspect, 'files', unit)
  const target = path.join(os.homedir(), unit)

  // Skip if target already exists
  if (await fs.pathExists(target)) {
    console.warn(`${unit} already exists. Won't change.`)
    return
  }

  // Prefer encrypted version if it exists
  if (await fs.pathExists(encryptedSource)) {
    await $`sops -d --output ${target} ${encryptedSource}`
    await $`chmod 600 ${target}`
    console.log(`decrypted ${unit}.encrypted -> ${unit}`)
  } else if (await fs.pathExists(plainSource)) {
    await fs.copy(plainSource, target)
    console.log(`copied ${unit}`)
  }
  // If neither exists, do nothing
})

await spinner('install keys', async () => {
  await $`sops -d --extract '["public_key"]' --output ~/.ssh/id_rsa.pub ${aspect}/key.yml`
  await $`sops -d --extract '["private_key"]' --output ~/.ssh/id_rsa ${aspect}/key.yml`
  await $`chmod 600 ~/.ssh/id_rsa*`
})
