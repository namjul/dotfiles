#!/usr/bin/env bash

# https://github.com/guettli/bash-strict-mode
trap 'echo "Warning: A command has failed. Exiting the script. Line was ($0:$LINENO): $(sed -n "${LINENO}p" "$0")"; exit 3' ERR
set -Eeuo pipefail

# Variables
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FILES_DIR="$SCRIPT_DIR/files"
TARGET_DIR="$HOME"

# Ensure base directories exist
mkdir -p "$HOME/.config"

# Process all files recursively
while IFS= read -r -d '' source_file; do
  # Calculate relative path from FILES_DIR
  rel_path="${source_file#$FILES_DIR/}"

  # Get filename and check for hard- prefix
  filename="$(basename "$source_file")"

  if [[ "$filename" == hard-* ]]; then
    # Hardlink: strip 'hard-' prefix for target
    is_hardlink=true
    target_name="${filename#hard-}"
    dir_path="$(dirname "$rel_path")"
    target_path="$TARGET_DIR/$dir_path/$target_name"
  else
    # Symlink: use same path
    is_hardlink=false
    target_path="$TARGET_DIR/$rel_path"
  fi

  # Ensure target directory exists (not symlinked)
  target_dir="$(dirname "$target_path")"

  # CRITICAL CHECK: Detect if parent directory is a symlink
  if [ -L "$target_dir" ]; then
    echo "WARNING: Target directory is a symlink: $target_dir"
    echo "  This may be a legacy directory-level symlink from old dotfiles setup."
    echo "  Please remove it and re-run this script:"
    echo "    rm '$target_dir'"
    echo "    mise run dotfiles"
    echo "  Skipping: $source_file"
    continue
  fi

  mkdir -p "$target_dir"

  # Skip if target already points to source (idempotent check)
  if [ -e "$target_path" ] || [ -L "$target_path" ]; then
    if [ "$source_file" -ef "$target_path" ]; then
      continue
    fi
  fi

  # Create link
  if $is_hardlink; then
    # Hardlink: use ln -f (force overwrite)
    if ! ln -f "$source_file" "$target_path"; then
      echo "ERROR: Failed to create hardlink"
      echo "  Source: $source_file"
      echo "  Target: $target_path"
      echo "  Hardlinks require source and target on same filesystem"
      exit 1
    fi
    echo "HARDLINK: $source_file -> $target_path"
  else
    # Symlink: use ln -sfn (force, no-dereference for dirs)
    ln -sfn "$source_file" "$target_path"
    echo "SOFTLINK: $source_file -> $target_path"
  fi
done < <(find "$FILES_DIR" -type f -print0)

echo "Dotfiles linking complete"
