#!/usr/bin/env bash

title=""
subtitle=""
message=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --title)    title="$2";    shift 2 ;;
    --subtitle) subtitle="$2"; shift 2 ;;
    --message)  message="$2";  shift 2 ;;
    *) shift ;;
  esac
done

summary="${title}"
[[ -n "$subtitle" ]] && summary="${title}: ${subtitle}"

notify-send "$summary" "$message"
